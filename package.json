{
  "name": "reco-gui",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tauri build --no-bundle",
    "build:python-worker": "uv run --directory src-python task bundle-worker",
    "check:bindings": "cargo run --quiet --manifest-path src-tauri/Cargo.toml --example generate-bindings -- --check src/generated/bindings.ts",
    "dev": "tauri dev",
    "fix": "pnpm --aggregate-output /^fix:/",
    "fix:python": "uv run --directory src-python task fix",
    "fix:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "fix:typescript": "oxlint --type-aware --type-check --fix && oxfmt",
    "format": "pnpm --aggregate-output /^format:/",
    "format:python": "uv run --directory src-python task format",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "format:typescript": "oxfmt",
    "generate:bindings": "cargo run --quiet --manifest-path src-tauri/Cargo.toml --example generate-bindings -- --write src/generated/bindings.ts",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "git config core.hooksPath .githooks",
    "lint": "pnpm --aggregate-output /^lint:/",
    "lint:python": "uv run --directory src-python task lint",
    "lint:rust": "pnpm build:python-worker && cargo clippy --manifest-path src-tauri/Cargo.toml --locked --all-targets --all-features -- -D warnings",
    "lint:typescript": "eslint && oxlint --type-aware --type-check",
    "test": "pnpm --aggregate-output /^test:/",
    "test:python": "uv run --directory src-python task test",
    "test:rust": "pnpm build:python-worker && cargo test --manifest-path src-tauri/Cargo.toml --locked --all-targets --all-features",
    "test:typescript": "vitest run",
    "typecheck": "pnpm --aggregate-output /^typecheck:/",
    "typecheck:python": "uv run --directory src-python task typecheck",
    "typecheck:typescript": "tsgo --noEmit",
    "verify": "pnpm --aggregate-output /^verify:/",
    "verify:python": "uv run --directory src-python task verify",
    "verify:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check && pnpm lint:rust && pnpm test:rust",
    "verify:typescript": "oxfmt --check && pnpm check:bindings && pnpm lint:typescript && pnpm typecheck:typescript && pnpm test:typescript && pnpm exec vite build"
  },
  "dependencies": {
    "@tauri-apps/api": "catalog:",
    "@tauri-apps/plugin-clipboard-manager": "catalog:",
    "@tauri-apps/plugin-opener": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "catalog:",
    "@tauri-apps/cli": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-oxlint": "catalog:",
    "jsdom": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "sort-package-json": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.10.0"
}
