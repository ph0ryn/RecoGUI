{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RecoGUI",
  "version": "../package.json",
  "identifier": "com.ph0ryn.recogui",
  "build": {
    "beforeDevCommand": "pnpm exec vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm typecheck:typescript && pnpm exec vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "decorations": true,
        "hiddenTitle": true,
        "label": "main",
        "title": "RecoGUI",
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 14,
          "y": 26
        },
        "width": 1120,
        "height": 720,
        "minWidth": 860,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self'; object-src 'none'; frame-src 'none'; base-uri 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../src-python/LICENSE": "src-python/LICENSE",
      "../src-python/SOURCE.md": "src-python/SOURCE.md",
      "../src-python/THIRD_PARTY_NOTICES.md": "src-python/THIRD_PARTY_NOTICES.md",
      "../src-python/pyproject.toml": "src-python/pyproject.toml",
      "../src-python/src/reco/*.py": "src-python/src/reco",
      "../src-python/src/reco/assets": "src-python/src/reco/assets",
      "../src-python/uv.lock": "src-python/uv.lock"
    },
    "macOS": {
      "minimumSystemVersion": "14.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
